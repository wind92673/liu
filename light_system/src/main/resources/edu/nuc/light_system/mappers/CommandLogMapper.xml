<?xml version = "1.0" encoding = "UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.nuc.light_system.mappers.CommandLogMapper">
	<!--实体映射-->
	<resultMap id="base_result_map" type="edu.nuc.light_system.entity.po.CommandLog">
		<!--自增id-->
		<id column="id" property="id"/>
		<!--操作类型-->
		<result column="event_type" property="eventType"/>
		<!--设备id-->
		<result column="device_id" property="deviceId"/>
		<!--指令内容-->
		<result column="command" property="command"/>
		<!--发送时间-->
		<result column="timestamp" property="timestamp"/>
	</resultMap>

	<!--通用查询结果列-->
	<sql id="base_column_list">
		id,event_type,device_id,command,timestamp
	</sql>

	<!--基础查询条件-->
	<sql id="base_query_condition">
		<if test="query.id != null">
			and id = #{query.id}
		</if>
		<if test="query.eventType != null and query.eventType!=''">
			and event_type = #{query.eventType}
		</if>
		<if test="query.deviceId != null and query.deviceId!=''">
			and device_id = #{query.deviceId}
		</if>
		<if test="query.command != null and query.command!=''">
			and command = #{query.command}
		</if>
		<if test="query.timestamp != null">
			and timestamp = #{query.timestamp}
		</if>
	</sql>

	<!--扩展查询条件-->
	<sql id="base_query_condition_extend">
		<if test="query.eventTypeFuzzy != null and query.eventTypeFuzzy !=''">
			and event_type like concat('%',#{query.eventTypeFuzzy},'%')
		</if>
		<if test="query.deviceIdFuzzy != null and query.deviceIdFuzzy !=''">
			and device_id like concat('%',#{query.deviceIdFuzzy},'%')
		</if>
		<if test="query.commandFuzzy != null and query.commandFuzzy !=''">
			and command like concat('%',#{query.commandFuzzy},'%')
		</if>
		<if test="query.timestampStart != null and query.timestampStart !=''">
			<![CDATA[ and timestamp >= str_to_date(#{query.timestampStart}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.timestampEnd != null and query.timestampEnd !=''">
			<![CDATA[ and timestamp < date_sub(str_to_date(#{query.timestampEnd}, '%Y-%m-%d'),interval -1 day) ]]>
		</if>
	</sql>

	<!--扩展查询条件-->
	<sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
	</sql>

	<!--查询列表-->
	<select id="selectList" resultMap="base_result_map">
		SELECT <include refid="base_column_list"/> FROM command_log<include refid="query_condition"/>
		<if test="query.orderBy!=null">order by ${query.orderBy}</if>
		<if test="query.simplePage!=null">limit #{query.simplePage.start},#{query.simplePage.end}</if>
	</select>

	<!--查询数量-->
	<select id="selectCount" resultType="java.lang.Integer">
		SELECT count(1) FROM command_log <include refid="query_condition"/>
	</select>

	<!--插入(匹配有值的字段)-->
	<insert id="insert" parameterType="edu.nuc.light_system.entity.po.CommandLog">
		INSERT INTO command_log
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id !=null">
				id,
			</if>
			<if test="bean.eventType !=null">
				event_type,
			</if>
			<if test="bean.deviceId !=null">
				device_id,
			</if>
			<if test="bean.command !=null">
				command,
			</if>
			<if test="bean.timestamp !=null">
				timestamp,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.id!=null">
				#{bean.id},
			</if>
			<if test="bean.eventType!=null">
				#{bean.eventType},
			</if>
			<if test="bean.deviceId!=null">
				#{bean.deviceId},
			</if>
			<if test="bean.command!=null">
				#{bean.command},
			</if>
			<if test="bean.timestamp!=null">
				#{bean.timestamp},
			</if>
		</trim>
	</insert>

	<!-- 插入或更新(匹配有值的字段) -->
	<insert id="insertOrUpdate" parameterType="edu.nuc.light_system.entity.po.CommandLog">
		INSERT INTO command_log
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.id !=null">
				id,
			</if>
			<if test="bean.eventType !=null">
				event_type,
			</if>
			<if test="bean.deviceId !=null">
				device_id,
			</if>
			<if test="bean.command !=null">
				command,
			</if>
			<if test="bean.timestamp !=null">
				timestamp,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.id!=null">
				#{bean.id},
			</if>
			<if test="bean.eventType!=null">
				#{bean.eventType},
			</if>
			<if test="bean.deviceId!=null">
				#{bean.deviceId},
			</if>
			<if test="bean.command!=null">
				#{bean.command},
			</if>
			<if test="bean.timestamp!=null">
				#{bean.timestamp},
			</if>
		</trim>
		on DUPLICATE key update
		<trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.eventType!=null">
				event_type = VALUES(event_type),
			</if>
			<if test="bean.deviceId!=null">
				device_id = VALUES(device_id),
			</if>
			<if test="bean.command!=null">
				command = VALUES(command),
			</if>
			<if test="bean.timestamp!=null">
				timestamp = VALUES(timestamp),
			</if>
		</trim>
	</insert>

	<!-- 添加(批量插入) -->
	<insert id="insertBatch" parameterType="edu.nuc.light_system.entity.po.CommandLog">
		INSERT INTO command_log(id,event_type,device_id,command,timestamp)values
		<foreach collection="list" item="item" separator="," >
			(#{item.id},#{item.eventType},#{item.deviceId},#{item.command},#{item.timestamp})
		</foreach>
	</insert>

	<!-- 批量插入或更新(批量插入) -->
	<insert id="insertOrUpdateBatch" parameterType="edu.nuc.light_system.entity.po.CommandLog">
		INSERT INTO command_log(id,event_type,device_id,command,timestamp)values
		<foreach collection="list" item="item" separator="," >
			(#{item.id},#{item.eventType},#{item.deviceId},#{item.command},#{item.timestamp})
		</foreach>
		on DUPLICATE key update
		id = VALUES(id),event_type = VALUES(event_type),device_id = VALUES(device_id),command = VALUES(command),timestamp = VALUES(timestamp)
	</insert>

	<!-- 根据Id查询-->
	<select id="selectById" resultMap="base_result_map">
		select <include refid="base_column_list"/>  from command_log where id=#{id}
	</select>

	<!-- 根据Id更新-->
	<update id="updateById" parameterType="edu.nuc.light_system.entity.po.CommandLog">
		update command_log
		<set>
			<if test="bean.id != null">
				id = #{bean.id},
			</if>
			<if test="bean.eventType != null">
				event_type = #{bean.eventType},
			</if>
			<if test="bean.deviceId != null">
				device_id = #{bean.deviceId},
			</if>
			<if test="bean.command != null">
				command = #{bean.command},
			</if>
			<if test="bean.timestamp != null">
				timestamp = #{bean.timestamp},
			</if>

		</set>
		where id=#{id}
</update>


	<!-- 根据Id删除-->
	<delete id="deleteById">
		delete from command_log where id=#{id}
</delete>

</mapper>